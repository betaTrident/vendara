---
type Props = {
  title: string;
  description?: string;
};

import "../styles/global.css";

const {
  title,
  description = "Vendara keeps sari-sari prices and customer ledgers in one place.",
} = Astro.props;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Outfit:wght@300;400;500;600;700;800;900&family=Geist+Mono:wght@300;400;500;600;700;800;900&display=swap"
      rel="stylesheet"
    />
    <title>{title}</title>
  </head>
  <body>
    <a href="#main-content" class="sr-only focus:not-sr-only focus:absolute focus:top-4 focus:left-4 focus:z-[100] focus:bg-ia-primary-container focus:text-ia-on-primary focus:px-4 focus:py-2 focus:rounded-md focus:font-semibold focus:outline-none">
      Skip to content
    </a>
    <slot />
  </body>
</html>
